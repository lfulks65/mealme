{
  "name": "@mealme/api",
  "version": "0.1.0",
  "description": "API client and shared types for the MealMe platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "seed:recipes": "npx tsx src/recipe/seed.ts"
  },
  "keywords": [
    "mealme",
    "api",
    "client"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@mealme/shared": "workspace:*",
    "@supabase/supabase-js": "^2.42.0",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "react": "^18.2.0"
  }
}
