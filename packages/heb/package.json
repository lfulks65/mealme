{
  "name": "@mealme/heb",
  "version": "0.1.0",
  "description": "HEB SDK integration layer for the MealMe platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --tsconfig tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mealme",
    "heb",
    "grocery",
    "sdk"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@mealme/shared": "workspace:*",
    "heb-sdk-unofficial": "^1.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
