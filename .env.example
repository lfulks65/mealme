# ============================================================================
# MealMe — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit real secrets to version control.
# ============================================================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Expo (React Native) — these are exposed to the client bundle
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Next.js — these are exposed to the client bundle
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# HEB Grocery Integration
HEB_STORE_ID=790
HEB_ZIP_CODE=78701
# HEB_SHOPPING_CONTEXT=CURBSIDE_PICKUP  # CURBSIDE_PICKUP | CURBSIDE_DELIVERY | EXPLORE_MY_STORE
# HEB_TIMEOUT=30000
# HEB_DEBUG=false
